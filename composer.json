{
    "name": "hypejunction/hypecapabilities",
    "type": "elgg-plugin",
    "version": "7.0.0",
    "description": "Roles and capabilities API",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypeCapabilities",
    "keywords": [
        "elgg",
        "plugin",
        "capabilities",
        "roles"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "extra": {
        "installer-name": "hypecapabilities",
        "elgg-plugin": {
            "id": "hypecapabilities"
        }
    },
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "composer/installers": "^2.0",
        "elgg/elgg": "~7.0.0"
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
